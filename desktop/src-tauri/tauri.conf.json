{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BizTrack",
  "version": "1.0.0",
  "identifier": "com.biztrack.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run prepare-next",
    "frontendDist": "../stub"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BizTrack",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["bundled/next"]
  }
}
